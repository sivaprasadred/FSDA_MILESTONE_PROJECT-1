# TrackWise Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# MySQL Database (XAMPP defaults)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=trackwise_db
DB_USER=root
DB_PASSWORD=

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=trackwise_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5
